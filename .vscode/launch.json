{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Deno Tests",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "deno",
      "runtimeArgs": ["test", "--inspect-brk", "--allow-read", "--allow-run", "tests/"],
      "attachSimplePort": 9229
    }
  ,
    {
      "name": "Debug Deno App",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "deno",
      "runtimeArgs": ["run", "--inspect-brk", "--allow-read", "src/main.ts"],
      "args": ["${input:moFilePath}"],
      "attachSimplePort": 9229
    }
  ],
  "inputs": [
    {
      "id": "moFilePath",
      "type": "promptString",
      "description": "Path to the .mo file",
      "default": "tests/models/SpringMassDamper.mo"
    }
  ]
}
